# =============================================================================
# Ceil — Local Environment Template
# Rename this file to `.env.local` for local development.
# =============================================================================

# Clerk Authentication (Get these from your Clerk dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Supabase (Get these from your Supabase project settings -> API)
# Used for dynamic pricing tables and quota lookups
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe Payment Link (Get this from your Stripe Dashboard -> Payment Links)
# Used for the $9/mo pro subscription tier
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_...
